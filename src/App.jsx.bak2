  var gs=props.gs,cyberSess=props.cyberSess,onCharChange=props.onCharChange,onMabelSend=props.onMabelSend,onStatBoost=props.onStatBoost,setCyberSess=props.setCyberSess,onNetrunMemory=props.onNetrunMemory;
